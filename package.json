{
  "name": "airpaste",
  "version": "0.1.0",
  "private": true,
  "author": "ragha",
  "description": "A local-first desktop canvas for link and note capture.",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.config.mjs",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "start": "electron .",
    "postinstall": "node scripts/install-playwright-browser.js",
    "lint": "eslint .",
    "build": "vite build --config vite.config.mjs",
    "package": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "open-graph-scraper": "^6.11.0",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.38.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.11",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.airpaste.app",
    "productName": "AirPaste",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-renderer/**/*",
      "main.js",
      "workspace-service.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
